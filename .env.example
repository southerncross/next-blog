# Copy this file to `.env.local` for local development.
# Production values are configured in the Vercel dashboard.
# Never commit a real `.env*` file.

# ---------------------------------------------------------------------------
# Auth0 (used by @auth0/nextjs-auth0 in src/app/api/auth/[auth0]/route.ts)
# ---------------------------------------------------------------------------
# A long random string. Generate with: openssl rand -hex 32
AUTH0_SECRET=
# Public base URL of this app (no trailing slash).
AUTH0_BASE_URL=http://localhost:3000
# Your Auth0 tenant URL, e.g. https://your-tenant.us.auth0.com
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Vercel Postgres (used by @vercel/postgres in src/lib/{data,actions}.ts and
# scripts/seed.js). On Vercel these are injected automatically; locally you
# can copy them from the project's "Storage" tab.
# ---------------------------------------------------------------------------
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# When set to a truthy value, posts with `preview: true` front-matter are
# included in listings. Leave empty in production.
PREVIEW_MODE=
